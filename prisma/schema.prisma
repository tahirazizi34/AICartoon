// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  studioName    String    @default("My Studio")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  episodes      Episode[]
  settings      StudioSettings?
  youtubeAuth   YouTubeAuth?

  @@map("users")
}

model Episode {
  id            String        @id @default(cuid())
  userId        String
  episodeNumber Int
  title         String
  description   String        @db.Text
  script        String        @db.Text
  status        EpisodeStatus @default(QUEUED)

  // File paths on disk / S3
  audioPath     String?
  videoPath     String?
  thumbnailPath String?

  // YouTube
  youtubeVideoId  String?
  youtubeUrl      String?
  publishedAt     DateTime?

  // Stats
  viewCount       Int       @default(0)
  likeCount       Int       @default(0)

  // Generation metadata
  generationLog   String?   @db.Text
  errorMessage    String?
  generatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("episodes")
}

model StudioSettings {
  id                String  @id @default(cuid())
  userId            String  @unique

  // Generation
  episodesPerDay    Int     @default(10)
  episodeDuration   Int     @default(120)   // seconds
  artStyle          String  @default("2D Cartoon")
  genre             String  @default("Comedy Adventure")
  characterNames    String  @default("")    // comma-separated
  scheduleEnabled   Boolean @default(true)
  scheduleSlots     String  @default("06:00,08:00,10:00,12:00,14:00,16:00,18:00,20:00,22:00,23:00")
  timezone          String  @default("America/New_York")

  // YouTube publish
  autoPublish       Boolean @default(true)
  defaultVisibility String  @default("public")
  addToPlaylist     Boolean @default(true)
  playlistId        String?
  autoCaptions      Boolean @default(false)

  // Notifications
  emailNotifications Boolean @default(true)

  // Encrypted API keys (encrypt at app layer before storing)
  anthropicKey      String?
  replicateKey      String?
  elevenLabsKey     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("studio_settings")
}

model YouTubeAuth {
  id            String    @id @default(cuid())
  userId        String    @unique
  channelId     String
  channelName   String
  channelHandle String?
  subscriberCount Int?

  accessToken   String    @db.Text
  refreshToken  String    @db.Text
  expiresAt     DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youtube_auth")
}

enum EpisodeStatus {
  QUEUED
  SCRIPTING
  VOICING
  RENDERING
  ASSEMBLING
  UPLOADING
  PUBLISHED
  FAILED
}
